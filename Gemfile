source "https://rubygems.org"

# Matches the exact gem set GitHub Pages runs in production, including the
# pinned Jekyll version and supported plugins (jekyll-seo-tag, jekyll-sitemap,
# jekyll-github-metadata, etc.). Run `bundle update github-pages` to refresh.
gem "github-pages", group: :jekyll_plugins

# Required for newer Ruby (3.0+) where these were removed from the standard library.
gem "webrick", "~> 1.8"
